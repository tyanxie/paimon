{
  "name": "@tyanxie/paimon",
  "version": "1.0.4",
  "description": "Remote observation and control panel for pi coding agent",
  "type": "module",
  "bin": {
    "paimon": "./src/cli/index.ts"
  },
  "pi": {
    "extensions": ["src/extensions"]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tyanxie/paimon.git"
  },
  "homepage": "https://github.com/tyanxie/paimon",
  "bugs": "https://github.com/tyanxie/paimon/issues",
  "keywords": ["pi", "pi-package", "coding-agent", "remote-panel", "websocket"],
  "scripts": {
    "dev": "vite build && concurrently -n hub,vite -c blue,green 'bun --watch src/hub/index.ts' 'vite build --watch'",
    "build": "vite build",
    "start": "bun src/hub/index.ts"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "commander": "^15.0.0",
    "highlight.js": "^11.11.1",
    "i18next": "^26.3.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router": "^7.15.0",
    "rehype-highlight": "^7.0.2",
    "remark-cjk-friendly": "^2.3.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "rotating-file-stream": "^3.2.9",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@happy-dom/global-registrator": "^20.10.6",
    "@tailwindcss/vite": "^4.1.5",
    "@types/bun": "^1.2.14",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^6.3.4"
  },
  "license": "MIT"
}
