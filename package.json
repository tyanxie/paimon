{
  "name": "paimon",
  "version": "0.1.0",
  "description": "Remote observation and control panel for pi coding agent",
  "type": "module",
  "bin": {
    "paimon": "./src/cli/index.ts"
  },
  "pi": {
    "extensions": ["src/extensions"]
  },
  "scripts": {
    "dev": "vite build && concurrently -n hub,vite -c blue,green 'bun --watch src/hub/index.ts' 'vite build --watch'",
    "build": "vite build",
    "start": "bun src/hub/index.ts"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "commander": "^15.0.0",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.15.0",
    "rehype-highlight": "^7.0.2",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@tailwindcss/vite": "^4.1.5",
    "@types/bun": "^1.2.14",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^6.3.4"
  },
  "license": "MIT"
}
